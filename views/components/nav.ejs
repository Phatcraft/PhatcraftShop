<style>
  nav{
    text-align: center;
    background-color: white;
    padding: 20px;
    padding-bottom: 5px;
  }
  nav h3{
    margin: 0;
  }
  nav .nav-bar{
    margin: 20px 0px;
    margin-bottom: 0;
  }
  nav .nav-bar a{
    font-size: 20px;
    padding: 4px 20px;
    background-color: var(--secondary);
    border-radius: 10px;
    color: white;
    position: relative;
  }
  nav .nav-bar a:hover{
    background-color: var(--primary);
  }
  nav .nav-bar a .ammount{
    font-size: 12px;
    left: 65%;
    top: -15%;
    background-color: red;
    position: absolute;
    padding: 2px 10px;
    border-radius: 10px;
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
  }
  nav .nav-bar .choose{
    padding: 6px 20px;
    background-color: var(--primary);
    border-radius: 10px 10px 0px 0px;
  }
</style>

<nav>
  <h3>Phatcraft Shop</h3>
  <div class="nav-bar">
    <a href="/" title="Trang chủ" <% if (page == "home") { %>class="choose"<% } %>><i class="bi bi-house-fill"></i></a>
    <a href="/account" title="Tài khoản" <% if (page == "account") { %>class="choose"<% } %>><i class="bi bi-person-fill"></i></a>
    <a href="" title="Giỏ hàng" <% if (page == "cart") { %>class="choose"<% } %>>
      <i class="bi bi-cart-fill"></i>
      <span class="ammount">0</span>
    </a>
  </div>
</nav>